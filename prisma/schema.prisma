// Prisma schema for Furnexa
// Update provider/url for MongoDB if needed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String
  role          Role     @default(USER)
  accounts      Account[]
  sessions      Session[]
  designs RoomDesign[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RoomDesign {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  name           String   @default("Untitled Design")
  roomSpecs      Json
  furnitureItems Json
  theme          Json?
  globalColors   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model CatalogFurnitureItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  slug       String   @unique
  groupId    String
  groupName  String
  groupOrder Int      @default(0)
  itemOrder  Int      @default(0)
  name       String
  width      Float
  length     Float
  color      String
  category   String
  modelPath  String
  modelId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CatalogRoomTemplate {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  slug                String   @unique
  name                String
  description         String
  icon                String
  thumbnail           String
  width               Float
  length              Float
  defaultFurniture    Json
  suggestedWallColor  String
  suggestedFloorColor String
  suggestedFloorType  String
  displayOrder        Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// NextAuth models
model Account {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId String @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}

model VerificationToken {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


